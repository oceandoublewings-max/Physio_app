<!-- ===== NEW STAMP モーダル：結果画面で表示 ===== -->
<div id="stamp-modal" role="dialog" aria-modal="true" aria-label="新しいスタンプを獲得">
  <div class="stamp-stage">
    <div class="stamp-image-wrap">
      <div class="stamp-glow"></div>

      <img
        id="stamp-modal-image"
        src=""
        alt="獲得したスタンプ"
      >
    </div>

    <div class="stamp-info">
      <div class="stamp-title">NEW STAMP!</div>

      <div id="stamp-modal-name"></div>

      <button
        type="button"
        class="stamp-ok-button"
        onclick="closeStampModal()"
      >
        OK
      </button>
    </div>
  </div>
</div>

<script>
function showStampModal(stamp) {
  if (!stamp || !stamp.image) return;

  const modal = document.getElementById("stamp-modal");
  const image = document.getElementById("stamp-modal-image");
  const name = document.getElementById("stamp-modal-name");

  if (!modal || !image || !name) return;

  image.src = stamp.image;
  name.textContent = stamp.name || "新しいスタンプ";

  // 同じページで再表示してもアニメーションを最初から再生
  modal.classList.remove("is-open");
  void modal.offsetWidth;
  modal.classList.add("is-open");

  document.body.style.overflow = "hidden";
}

function closeStampModal() {
  const modal = document.getElementById("stamp-modal");

  if (modal) {
    modal.classList.remove("is-open");
  }

  document.body.style.overflow = "";
}
</script>
