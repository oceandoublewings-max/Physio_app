<style>
.image-row {
  display: flex;
  gap: 20px;
  justify-content: center;
}

/* スマホだけ縦並び */
@media (max-width: 768px) {
  .image-row {
    flex-direction: column;
    align-items: center;
  }

  .image-row img {
    width: 90% !important;
  }
}
</style>

<h2>参考資料</h2>

<% if params[:type] == "bone" %>
  <h3>骨の参考資料</h3>

  <div class="image-row">
    <% Dir.glob(Rails.root.join("public/images/bone/*")).each do |img| %>
      <img src="<%= img.sub(Rails.root.join('public').to_s, '') %>" width="300">
    <% end %>
  </div>

<% elsif params[:type] == "muscle" %>
  <h3>筋肉の参考資料</h3>

  <div class="image-row">
    <% Dir.glob(Rails.root.join("public/images/muscle/*")).each do |img| %>
      <img src="<%= img.sub(Rails.root.join('public').to_s, '') %>" width="300">
    <% end %>
  </div>

<% else %>
  <div style="text-align:center; margin-top:30px;">

  <a href="/anatomy_pdfs" style="
    display:block;
    width:80%;
    margin:20px auto;
    padding:20px;
    background:white;
    border:1px solid #ddd;
    border-radius:12px;
    text-decoration:none;
    color:black;
    font-size:28px;
    font-weight:bold;
  ">
    📚 解剖学
  </a>

  <a href="/physiology_pdfs" style="
    display:block;
    width:80%;
    margin:20px auto;
    padding:20px;
    background:white;
    border:1px solid #ddd;
    border-radius:12px;
    text-decoration:none;
    color:black;
    font-size:28px;
    font-weight:bold;
  ">
    🫀 生理学
  </a>

 <div style="
  display:block;
  width:80%;
  margin:20px auto;
  padding:20px;
  background:#dcdcdc;
  border:1px solid #ddd;
  border-radius:12px;
  color:#666;
  font-size:28px;
  font-weight:bold;
">
  🏃 運動学（準備中）
</div>

</div>
<% end %>