<div style="
  max-width: 700px;
  margin: 20px auto;
  text-align: center;
">

  <h1 style="
     font-size: 28px;
  margin-bottom: 16px;
  margin-top: 8px;
  ">
    🏃 運動学 苦手分析
  </h1>

  <div id="kinesiology-box" style="
    background: white;
    padding: 10px 16px;
    border-radius: 18px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    font-size: 18px;
    font-weight: bold;
    line-height: 1.6;
  ">
  </div>

</div>

<div style="
  margin-top: 20px;
  background: white;
  padding: 20px;
  border-radius: 18px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
">

  <h2 style="
    font-size:22px;
    margin-bottom:20px;
  ">
    ⭐ 分野別 苦手度チャート
  </h2>

  <div style="
    height:300px;
    display:flex;
    justify-content:center;
    align-items:center;
    color:#999;
    border:2px dashed #ddd;
    border-radius:12px;
  ">
    ここにレーダーチャートが入ります
  </div>

</div>

<script>
const wrong = JSON.parse(localStorage.getItem("wrong")) || []

let kinesiology = 0

let jointMotion = 0
let rom = 0
let muscleAction = 0
let gait = 0
let posture = 0
let biomechanics = 0
let movementAnalysis = 0

wrong.forEach(q => {

  if(q.category === "運動") kinesiology++

  if(q.subcategory === "関節運動") jointMotion++
  if(q.subcategory === "ROM") rom++
  if(q.subcategory === "筋作用") muscleAction++
  if(q.subcategory === "歩行") gait++
  if(q.subcategory === "姿勢") posture++
  if(q.subcategory === "バイオメカニズム") biomechanics++
  if(q.subcategory === "動作分析") movementAnalysis++

})

document.getElementById("kinesiology-box").innerHTML = `
🏃 運動学：${kinesiology}問<br><br>

🦴 関節運動：${jointMotion}問<br>
📏 ROM：${rom}問<br>
💪 筋作用：${muscleAction}問<br>
🚶 歩行：${gait}問<br>
🧍 姿勢：${posture}問<br>
⚙️ バイオメカニズム：${biomechanics}問<br>
🎥 動作分析：${movementAnalysis}問
`;
</script>