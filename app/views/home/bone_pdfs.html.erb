<h1 style="
  text-align:center;
  font-size:34px;
  line-height:1.2;
  margin-top:30px;
  margin-bottom:40px;
">
  🦴 骨資料集
</h1>

<div style="
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:20px;
  width:85%;
  margin:0 auto;
">

  <% (1..48).each do |i| %>

    <a href="/pdfs/bone/bone_<%= "%03d" % i %>.pdf"
       target="_blank"
       style="text-decoration:none;">

      <div style="
        background:#f5f7fa;
        border:1px solid #e5e5e5;
        padding:14px;
        border-radius:15px;
        box-shadow:0 2px 6px rgba(0,0,0,0.1);
        text-align:center;
        font-size:18px;
        font-weight:bold;
        color:black;
      ">

        📄 <%= "%03d" % i %>

      </div>

    </a>

  <% end %>

</div>