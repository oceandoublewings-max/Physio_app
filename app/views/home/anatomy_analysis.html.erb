<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
  * {
    box-sizing: border-box;
  }

  body {
    background:
      radial-gradient(circle at 15% 10%, rgba(214, 179, 82, 0.08), transparent 24%),
      linear-gradient(180deg, #f7f9fc 0%, #eef3f9 100%);
  }

  .analysis-page {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    padding: 16px 14px 36px;
    color: #102d52;
  }

  /* =========================
     HERO
  ========================= */
  .analysis-hero {
    position: relative;
    overflow: hidden;
    min-height: 270px;
    padding: 30px 30px 28px;
    border-radius: 0 0 34px 34px;
    background:
      radial-gradient(circle at 85% 25%, rgba(255,255,255,0.10), transparent 24%),
      linear-gradient(135deg, #062b52 0%, #0b467a 62%, #28618d 100%);
    box-shadow: 0 18px 36px rgba(10, 45, 82, 0.20);
  }

  .analysis-hero::before,
  .analysis-hero::after {
    content: "";
    position: absolute;
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 50%;
    pointer-events: none;
  }

  .analysis-hero::before {
    width: 240px;
    height: 240px;
    right: -110px;
    top: -90px;
  }

  .analysis-hero::after {
    width: 180px;
    height: 180px;
    right: -55px;
    bottom: -110px;
  }

  .hero-top {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .hero-brand {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    color: rgba(255,255,255,0.82);
  }

  .top-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 18px;
    border: 1px solid rgba(220, 184, 86, 0.85);
    border-radius: 999px;
    color: #e4c56d;
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    background: rgba(255,255,255,0.03);
  }

  .hero-main {
    position: relative;
    z-index: 2;
    margin-top: 34px;
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .hero-icon {
    width: 76px;
    height: 76px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid rgba(220, 184, 86, 0.75);
    background: rgba(255,255,255,0.06);
    font-size: 34px;
    box-shadow: inset 0 0 24px rgba(255,255,255,0.04);
  }

  .hero-title-wrap {
    min-width: 0;
  }

  .hero-title {
    margin: 0;
    color: white;
    font-size: 36px;
    font-family: "Yu Mincho", "Hiragino Mincho ProN", serif;
    font-weight: 600;
    letter-spacing: 5px;
    line-height: 1.15;
  }

  .hero-en {
    margin-top: 8px;
    color: #e0bd5f;
    font-family: Georgia, serif;
    font-size: 12px;
    letter-spacing: 3px;
  }

  .hero-message {
    position: relative;
    z-index: 2;
    margin: 28px 0 0;
    text-align: center;
    color: rgba(255,255,255,0.88);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1px;
  }

  /* =========================
     SECTION TITLE
  ========================= */
  .section-title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 13px;
    margin: 32px 0 20px;
    color: #102d52;
    font-family: "Yu Mincho", "Hiragino Mincho ProN", serif;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .section-title::before,
  .section-title::after {
    content: "";
    width: 42px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #c9a33e);
  }

  .section-title::after {
    background: linear-gradient(90deg, #c9a33e, transparent);
  }

  /* =========================
     SUMMARY
  ========================= */
  .summary-card {
    overflow: hidden;
    background: rgba(255,255,255,0.96);
    border: 1px solid rgba(18, 54, 92, 0.08);
    border-radius: 24px;
    box-shadow: 0 12px 28px rgba(17, 48, 82, 0.10);
  }

  .total-area {
    padding: 22px 20px 18px;
    text-align: center;
    background:
      linear-gradient(135deg, rgba(7, 49, 88, 0.035), rgba(214, 179, 82, 0.07));
    border-bottom: 1px solid #edf0f4;
  }

  .total-label {
    color: #6b7890;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .total-number {
    margin-top: 3px;
    color: #102d52;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 45px;
    font-weight: 700;
    line-height: 1;
  }

  .total-number span {
    margin-left: 5px;
    color: #b28b2d;
    font-family: sans-serif;
    font-size: 15px;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    padding: 16px;
  }

  .category-item {
    min-width: 0;
    min-height: 82px;
    padding: 10px 9px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
    background: #fff;
    border: 1px solid #e8edf3;
    border-radius: 15px;
    box-shadow: 0 4px 12px rgba(19, 49, 83, 0.05);
  }

  .category-left {
    min-width: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .category-icon {
    font-size: 23px;
    line-height: 1;
  }

  .category-name {
    margin-top: 5px;
    color: #52647a;
    font-size: 11px;
    font-weight: 700;
    white-space: nowrap;
  }

  .category-count {
    flex-shrink: 0;
    color: #102d52;
    font-family: Georgia, serif;
    font-size: 21px;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }

  .category-count span {
    margin-left: 2px;
    color: #7b8795;
    font-family: sans-serif;
    font-size: 10px;
  }

  /* =========================
     WORST AREA
  ========================= */
  .weakest-card {
    margin: 0 16px 18px;
    padding: 1px;
    border-radius: 19px;
    background: linear-gradient(135deg, #c29b38, #f2d77d, #9b7420);
  }

  .weakest-inner {
    position: relative;
    overflow: hidden;
    padding: 19px 16px 17px;
    border-radius: 18px;
    text-align: center;
    background:
      radial-gradient(circle at 85% 20%, rgba(255,255,255,0.10), transparent 25%),
      linear-gradient(135deg, #082f59, #124f82);
  }

  .weakest-inner::after {
    content: "";
    position: absolute;
    width: 120px;
    height: 120px;
    right: -60px;
    bottom: -70px;
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 50%;
  }

  .weakest-label {
    position: relative;
    z-index: 2;
    color: #e4c56d;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .weakest-title {
    position: relative;
    z-index: 2;
    margin-top: 5px;
    color: white;
    font-size: 18px;
    font-weight: 700;
  }

  .weakest-list {
    position: relative;
    z-index: 2;
    margin-top: 9px;
    color: white;
    font-size: 15px;
    font-weight: 600;
    line-height: 1.7;
  }

  .weakest-tip {
    position: relative;
    z-index: 2;
    margin-top: 9px;
    padding-top: 9px;
    border-top: 1px solid rgba(255,255,255,0.14);
    color: rgba(255,255,255,0.68);
    font-size: 11px;
  }

  /* =========================
     CHART
  ========================= */
  .chart-card {
    margin-top: 18px;
    padding: 20px 14px 14px;
    background: rgba(255,255,255,0.96);
    border: 1px solid rgba(18, 54, 92, 0.08);
    border-radius: 24px;
    box-shadow: 0 12px 28px rgba(17, 48, 82, 0.10);
  }

  .chart-heading {
    text-align: center;
  }

  .chart-kicker {
    color: #b28b2d;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .chart-title {
    margin-top: 4px;
    color: #102d52;
    font-family: "Yu Mincho", "Hiragino Mincho ProN", serif;
    font-size: 21px;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .chart-wrap {
    height: 350px;
    margin-top: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .chart-note {
    margin: 4px 5px 0;
    padding-top: 10px;
    border-top: 1px solid #edf0f4;
    text-align: center;
    color: #8a94a1;
    font-size: 10px;
  }

  @media (max-width: 420px) {
    .analysis-page {
      padding: 6px 10px 24px;
    }

    .analysis-hero {
      min-height: 145px;
      padding: 15px 18px 14px;
      border-radius: 0 0 26px 26px;
    }

    .hero-brand {
      font-size: 8px;
      letter-spacing: 1.8px;
    }

    .top-button {
      padding: 6px 12px;
      font-size: 9px;
    }

    .hero-main {
      margin-top: 13px;
      gap: 11px;
    }

    .hero-icon {
      width: 48px;
      height: 48px;
      font-size: 23px;
    }

    .hero-title {
      font-size: 27px;
      letter-spacing: 3px;
    }

    .hero-en {
      margin-top: 3px;
      font-size: 8px;
      letter-spacing: 1.8px;
    }

    .hero-message {
      margin: 10px 0 0;
      font-size: 10px;
      letter-spacing: 0;
      white-space: nowrap;
    }

    .section-title {
      margin: 17px 0 12px;
      font-size: 20px;
      gap: 10px;
    }

    .section-title::before,
    .section-title::after {
      width: 28px;
    }

    .total-area {
      padding: 12px 16px 10px;
    }

    .total-label {
      font-size: 9px;
      letter-spacing: 1.7px;
    }

   .total-number {
  margin-top: 2px;
  font-family: sans-serif;
  font-size: 16px;
  font-weight: 700;
}

    .total-number span {
      font-size: 12px;
    }

    .category-grid {
      gap: 7px;
      padding: 10px;
    }

    .category-item {
      min-height: 64px;
      padding: 7px 7px;
      gap: 3px;
      border-radius: 12px;
    }

    .category-icon {
      font-size: 18px;
    }

    .category-name {
      margin-top: 3px;
      font-size: 9px;
    }

    .category-count {
      font-size: 15px;
    }

    .category-count span {
      font-size: 8px;
    }

    .weakest-card {
      margin: 0 10px 12px;
      border-radius: 15px;
    }

    .weakest-inner {
      padding: 10px 12px 9px;
      border-radius: 14px;
    }

    .weakest-label {
      font-size: 8px;
      letter-spacing: 1.6px;
    }

    .weakest-title {
      margin-top: 3px;
      font-size: 14px;
    }

    .weakest-list {
      margin-top: 4px;
      font-size: 12px;
      line-height: 1.4;
    }

    .weakest-tip {
      margin-top: 5px;
      padding-top: 5px;
      font-size: 9px;
    }

    .chart-card {
      margin-top: 12px;
      padding: 14px 10px 10px;
    }

    .chart-kicker {
      font-size: 8px;
    }

    .chart-title {
      margin-top: 2px;
      font-size: 18px;
    }

    .chart-wrap {
      height: 315px;
      margin-top: 4px;
    }
  }
</style>

<div class="analysis-page">

  <section class="analysis-hero">
    <div class="hero-top">
      <div class="hero-brand">PT NATIONAL EXAM PREP</div>

      <%= link_to root_path, class: "top-button" do %>
        ← TOP
      <% end %>
    </div>

    <div class="hero-main">
      <div class="hero-icon">🦴</div>

      <div class="hero-title-wrap">
        <h1 class="hero-title">解剖学</h1>
        <div class="hero-en">WEAKNESS ANALYSIS</div>
      </div>
    </div>

    <p class="hero-message">
      苦手を「見える化」して、効率的に克服しよう
    </p>
  </section>


  <div class="section-title">
    苦手分析
  </div>


  <section class="summary-card">
    <div class="total-area">
      <div class="total-label">TOTAL WEAK QUESTIONS</div>

      <div class="total-number">
        <span id="anatomy-total">0</span><span>問</span>
      </div>
    </div>


    <div class="category-grid">

      <div class="category-item">
        <div class="category-left">
          <div class="category-icon">🦴</div>
          <div class="category-name">骨</div>
        </div>
        <div class="category-count">
          <span id="bone-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item">
        <div class="category-left">
          <div class="category-icon">💪</div>
          <div class="category-name">筋肉</div>
        </div>
        <div class="category-count">
          <span id="muscle-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item">
        <div class="category-left">
          <div class="category-icon">🧠</div>
          <div class="category-name">神経</div>
        </div>
        <div class="category-count">
          <span id="nerve-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item">
        <div class="category-left">
          <div class="category-icon">🫀</div>
          <div class="category-name">臓器</div>
        </div>
        <div class="category-count">
          <span id="organ-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item">
        <div class="category-left">
          <div class="category-icon">🩸</div>
          <div class="category-name">血管</div>
        </div>
        <div class="category-count">
          <span id="vessel-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item">
        <div class="category-left">
          <div class="category-icon">📍</div>
          <div class="category-name">断面・位置</div>
        </div>
        <div class="category-count">
          <span id="position-count">0</span><span>問</span>
        </div>
      </div>

    </div>

    <div id="weakest-area"></div>
  </section>


  <section class="chart-card">

    <div class="chart-heading">
      <div class="chart-kicker">WEAKNESS BALANCE</div>
      <div class="chart-title">分野別 苦手度チャート</div>
    </div>

    <div class="chart-wrap">
      <canvas id="radarChart"></canvas>
    </div>

    <p class="chart-note">
      ※ レーダーチャートは5択・○×問題のみ集計しています
    </p>

  </section>

</div>


<script>
const wrong = JSON.parse(localStorage.getItem("wrong")) || []

let anatomy = 0

let bone = 0
let muscle = 0
let nerve = 0
let organ = 0
let vessel = 0
let position = 0

wrong.forEach(q => {

  if(q.category === "解剖") anatomy++

  if(q.subcategory === "骨") bone++
  if(q.subcategory === "筋肉") muscle++
  if(q.subcategory === "神経") nerve++
  if(q.subcategory === "臓器") organ++
  if(q.subcategory === "血管") vessel++
  if(q.subcategory === "断面・位置関係") position++

})


document.getElementById("anatomy-total").textContent = anatomy
document.getElementById("bone-count").textContent = bone
document.getElementById("muscle-count").textContent = muscle
document.getElementById("nerve-count").textContent = nerve
document.getElementById("organ-count").textContent = organ
document.getElementById("vessel-count").textContent = vessel
document.getElementById("position-count").textContent = position


const weakAreas = [
  { name: "骨", icon: "🦴", count: bone },
  { name: "筋肉", icon: "💪", count: muscle },
  { name: "神経", icon: "🧠", count: nerve },
  { name: "臓器", icon: "🫀", count: organ },
  { name: "血管", icon: "🩸", count: vessel },
  { name: "断面・位置関係", icon: "📍", count: position }
]

const maxWeak = Math.max(...weakAreas.map(a => a.count))

if (maxWeak > 0) {

  const topWeak = weakAreas.filter(a => a.count === maxWeak)

  document.getElementById("weakest-area").innerHTML = `
    <div class="weakest-card">
      <div class="weakest-inner">

        <div class="weakest-label">
          MOST DIFFICULT AREA
        </div>

        <div class="weakest-title">
          🥇 一番苦手：${topWeak.map(a => a.name).join("・")}
        </div>

        <div class="weakest-tip">
          💡 次に勉強すると効果的！
        </div>

      </div>
    </div>
  `
}


const ctx = document.getElementById("radarChart")

new Chart(ctx, {
  type: "radar",

  data: {
    labels: [
      "骨",
      "筋肉",
      "神経",
      "臓器",
      "血管",
      "断面"
    ],

    datasets: [{
      label: "苦手問題数",

      data: [
        bone,
        muscle,
        nerve,
        organ,
        vessel,
        position
      ],

      borderColor: "#b28b2d",
      backgroundColor: "rgba(178, 139, 45, 0.18)",
      pointBackgroundColor: "#0b467a",
      pointBorderColor: "#ffffff",
      pointBorderWidth: 2,
      pointRadius: 5,
      borderWidth: 3
    }]
  },

  options: {
    responsive: true,
    maintainAspectRatio: false,

    plugins: {
      legend: {
        display: false
      }
    },

    scales: {
      r: {
        beginAtZero: true,

        angleLines: {
          color: "rgba(16, 45, 82, 0.12)"
        },

        grid: {
          color: "rgba(16, 45, 82, 0.12)"
        },

        pointLabels: {
          color: "#52647a",
          font: {
            size: 12,
            weight: "bold"
          }
        },

        ticks: {
          stepSize: 1,
          color: "#8995a5",
          backdropColor: "transparent",
          font: {
            size: 10
          }
        }
      }
    }
  }
})
</script>