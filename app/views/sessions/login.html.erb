<!-- login.html.erb 完全版（改善版） -->
<style>
*{box-sizing:border-box}
body{margin:0;background:#eef3f9;font-family:sans-serif;color:#102847;}
.login-page{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:12px;}
.login-card{width:100%;max-width:430px;background:#fff;border-radius:24px;overflow:hidden;box-shadow:0 12px 35px rgba(0,0,0,.12);}
.hero{position:relative;padding:22px 20px;text-align:center;color:#fff;background:linear-gradient(135deg,#041e42 0%,#0a4278 100%);}
.hero h1{margin:0;font-size:30px;font-family:serif;}
.hero p{margin:8px 0 0;color:#d8bd73;font-size:12px;letter-spacing:1px;line-height:1.4;}
.hero .hero-skeleton{position:absolute;top:2px;right:4px;}
.hero .hero-skeleton img{width:68px;height:auto;}
.content{padding:20px;}
h2{margin:0;text-align:center;font-size:20px;}
.description{margin:10px 0 18px;text-align:center;color:#666;line-height:1.6;font-size:16px;}
.guest-btn,.google-btn{display:block;width:100%;padding:15px;border:none;border-radius:14px;color:#fff;font-size:18px;font-weight:bold;text-align:center;text-decoration:none;cursor:pointer;}
.guest-btn{background:linear-gradient(180deg,#3d86ea,#2d6fd3);}
.google-btn{background:#34a853;margin-bottom:12px;}
.guest-badges{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin:16px 0 4px;}
.guest-badges span{background:#eef5ff;color:#1b3763;padding:5px 10px;border-radius:999px;font-size:12px;font-weight:700;}
.box{margin-top:20px;padding:15px;border-radius:14px;background:#f8fbff;border:1px solid #dfe6ef;}
.box h3{margin:0 0 12px;text-align:center;font-size:20px;}
.box ul{margin:0;padding-left:22px;line-height:1.8;}
.login-area{margin-top:22px;text-align:center;color:#666;line-height:1.7;}
.login-title{display:block;margin-bottom:12px;color:#102847;font-size:18px;}
.preparing{margin:12px 0;font-size:15px;}
.guest-note{margin-top:16px;font-size:14px;color:#666;line-height:1.7;}
</style>

<div class="login-page">
  <div class="login-card">
    <div class="hero">
      <div class="hero-skeleton">
        <img src="/images/stamps/stamp_003.png" alt="ガイコツくん">
      </div>

      <h1>⚕ PT・OT共通<br>基礎学習</h1>
      <p>PHYSICAL THERAPIST NATIONAL EXAM PREP</p>
    </div>

    <div class="content">

      <h2>まずはゲストでお試し！</h2>

      <p class="description">
        登録不要ですぐ学習できます。<br>
        Googleで無料登録すると、<br>
        学習データや苦手分析を保存できます。
      </p>

      <%= button_to "🚀 今すぐゲストで始める",
          "/guest_login",
          method: :post,
          class: "guest-btn" %>

      <div class="guest-badges">
        <span>✅ 問題演習無料</span>
        <span>⚡ 登録不要</span>
        <span>📚 すぐ始める</span>
      </div>

      <div class="box">
        <h3>登録すると使える機能</h3>
        <ul>
          <li>📊 苦手分析レーダー</li>
          <li>📈 分野別分析</li>
          <li>🏅 スタンプ保存</li>
          <li>☁️ 学習データ保存・引き継ぎ</li>
          <li>📖 PDF資料集の購入</li>
        </ul>
      </div>

      <div class="login-area">
        <strong class="login-title">無料登録はこちら</strong>

        <%= button_to user_google_oauth2_omniauth_authorize_path,
            method: :post,
            data: { turbo: false },
            class: "google-btn" do %>
          G&nbsp;&nbsp;Googleでログイン
        <% end %>

        <div class="preparing">🍎 Appleでログイン（準備中）</div>
        <div class="preparing">✉️ メールアドレスでログイン（準備中）</div>

        <div class="guest-note">
          ゲストは登録不要ですぐに始められます。<br>
          学習データの保存・苦手分析はGoogleログイン後に利用できます。<br><br>

          <small>
            <%= link_to "利用規約", "/terms", style: "color:#666;text-decoration:none;" %>
            ｜ 
            <%= link_to "プライバシーポリシー", "/privacy", style: "color:#666;text-decoration:none;" %>
          </small>
        </div>
      </div>
    </div>
  </div>
</div>
