<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div style="
  max-width: 700px;
  margin:5px auto 15px;
  text-align: center;
">

 <h1 style="
  font-size:24px;
  margin-top:0;
  margin-bottom:10px;
">
  🏃 運動学 苦手分析
</h1>

  <div id="kinesiology-box" style="
    background: white;
    padding: 10px 16px;
    border-radius: 18px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    font-size: 18px;
    font-weight: bold;
    line-height: 1.6;
  ">
  </div>

</div>

<div style="
  margin-top: 12px;
  background: white;
  padding: 16px;
  border-radius: 18px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
">

  <h2 style="
  font-size:18px;
  margin-bottom:10px;
">
  ⭐ 分野別 苦手度チャート
</h2>

  <div style="
    height:360px;
    display:flex;
    justify-content:center;
    align-items:center;
    color:#999;
    border-radius:12px;
  ">
    <canvas id="radarChart"></canvas>
  </div>
<p style="
  text-align:right;
  font-size:11px;
  color:#888;
  margin-top:8px;
  margin-bottom:0;
  padding-right:8px;
">
  ※ レーダーチャートは5択・○×問題のみ集計しています
</p>

</div>

<script>
const wrong = JSON.parse(localStorage.getItem("wrong")) || []

let kinesiology = 0

let jointMotion = 0
let rom = 0
let muscleAction = 0
let gait = 0
let posture = 0
let biomechanics = 0
let movementAnalysis = 0

wrong.forEach(q => {

  if(q.category === "運動") kinesiology++

  if(q.subcategory === "関節運動") jointMotion++
  if(q.subcategory === "ROM") rom++
  if(q.subcategory === "筋作用") muscleAction++
  if(q.subcategory === "歩行") gait++
  if(q.subcategory === "姿勢") posture++
  if(q.subcategory === "バイオメカニズム") biomechanics++
  if(q.subcategory === "動作分析") movementAnalysis++

})

const weakAreas = [
  { name: "関節運動", icon: "🦴", count: jointMotion },
  { name: "ROM", icon: "📏", count: rom },
  { name: "筋作用", icon: "💪", count: muscleAction },
  { name: "歩行", icon: "🚶", count: gait },
  { name: "姿勢", icon: "🧍", count: posture },
  { name: "バイオメカニズム", icon: "⚙️", count: biomechanics },
  { name: "動作分析", icon: "🎥", count: movementAnalysis }
];

const maxWeak = Math.max(...weakAreas.map(a => a.count));

let weakMessage = "";

if (maxWeak > 0) {
  const topWeak = weakAreas.filter(a => a.count === maxWeak);

  weakMessage = `
  <div style="
    margin-top:16px;
    padding:14px;
    background:#F8FBFF;
    border:1px solid #D6E8FF;
    border-radius:12px;
    text-align:center;
  ">

    <div style="
      font-size:18px;
      font-weight:bold;
    ">
      🥇 一番苦手：${topWeak.map(a => a.name).join("・")}
    </div>

    <div style="
      margin-top:8px;
      font-size:16px;
    ">
      ${topWeak.map(a => `${a.icon} ${a.name}（${a.count}問）`).join("<br>")}
    </div>

    <div style="
      margin-top:8px;
      font-size:14px;
      color:#666;
    ">
      💡 次に勉強すると効果的！
    </div>

  </div>
  `;
}

document.getElementById("kinesiology-box").innerHTML = `

🏃 運動学：${kinesiology}問<br><br>

🦴 関節運動：${jointMotion}問<br>
📏 ROM：${rom}問<br>
💪 筋作用：${muscleAction}問<br>
🚶 歩行：${gait}問<br>
🧍 姿勢：${posture}問<br>
⚙️ バイオメカニズム：${biomechanics}問<br>
🎥 動作分析：${movementAnalysis}問

${weakMessage}
`;
const ctx = document.getElementById("radarChart");

new Chart(ctx, {
  type: "radar",
  data: {
    labels: [
      "関節運動",
      "ROM",
      "筋作用",
      "歩行",
      "姿勢",
      "バイオ",
      "動作分析"
    ],
    datasets: [{
      label: "苦手問題数",
      data: [
  jointMotion,
  rom,
  muscleAction,
  gait,
  posture,
  biomechanics,
  movementAnalysis
],
borderColor: "#4A90E2",
backgroundColor: "rgba(74,144,226,0.25)",
pointBackgroundColor: "#4A90E2",
pointBorderColor: "#4A90E2",
borderWidth: 4
 }]
},
options: 
    responsive: true,
    plugins: {
      legend: {
        display: false
      }
    },
    scales: {
      r: {
        beginAtZero: true,
        ticks: {
          stepSize: 1
        }
      }
    }
  }
});
</script>