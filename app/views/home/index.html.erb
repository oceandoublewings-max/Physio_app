<script>
function goWrong(category) {
  const wrong = JSON.parse(localStorage.getItem("wrong")) || [];

  if (wrong.length === 0) {
    alert("苦手問題がまだありません");
    return;
  }

  window.location.href =
    "/select?mode=wrong&ids=" + wrong.join(",") +
    "&category=" + category +
    "&qtype=choice&index=0";
}
</script>

<script>
const wrong = JSON.parse(localStorage.getItem("wrong")) || []
console.log(wrong)

let anatomy = 0
let physiology = 0
let kinesiology = 0

let bone = 0
let muscle = 0
let nerve = 0
let organ = 0
let vessel = 0
let position = 0


wrong.forEach(q => {
  if (q.category === "解剖") anatomy++
  if (q.category === "生理") physiology++
  if (q.category === "運動") kinesiology++

  if (q.subcategory === "骨") bone++
  if (q.subcategory === "筋肉") muscle++
  if(q.subcategory === "神経") nerve++
  if(q.subcategory === "臓器") organ++
  if(q.subcategory === "血管") vessel++
  if(q.subcategory === "断面・位置関係") position++
})

document.getElementById("analysis-box").innerHTML = `
