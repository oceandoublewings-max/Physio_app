<style>
  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at 50% 0%, rgba(25, 76, 130, 0.05), transparent 38%),
      #f5f8fc;
    color: #0b2343;
  }

  .select-page {
    width: min(92%, 520px);
    margin: 0 auto;
    padding: 22px 0 45px;
  }

  /* =========================
     分野ヘッダー
  ========================= */
  .category-hero {
    position: relative;
    overflow: hidden;
    border-radius: 0 0 28px 28px;
    padding: 14px 18px 15px;
    margin-bottom: 16px;
    background:
      radial-gradient(circle at 88% 18%, rgba(255,255,255,0.13), transparent 32%),
      linear-gradient(135deg, #082548 0%, #0d3a69 58%, #174f82 100%);
    box-shadow: 0 12px 30px rgba(9, 40, 77, 0.16);
  }

  .category-hero::before {
    content: "";
    position: absolute;
    width: 190px;
    height: 190px;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 50%;
    right: -70px;
    top: -80px;
  }

  .category-hero::after {
    content: "";
    position: absolute;
    width: 135px;
    height: 135px;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 50%;
    right: 12px;
    bottom: -90px;
  }

  .hero-top-row {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .category-label {
    margin: 0;
    color: rgba(255,255,255,0.72);
    font-size: 11px;
    letter-spacing: 0.18em;
    font-weight: 700;
  }

  .top-link {
    flex-shrink: 0;
    text-decoration: none;
    color: #f0d58c;
    border: 1px solid rgba(232, 201, 118, 0.65);
    border-radius: 999px;
    padding: 5px 11px;
    font-size: 10px;
    font-weight: 700;
    background: rgba(255,255,255,0.05);
  }

  .category-title-wrap {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 8px;
  }

  .category-icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 20px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(236, 207, 132, 0.55);
    box-shadow: inset 0 0 20px rgba(255,255,255,0.05);
  }

  .category-title {
    margin: 0;
    color: #fff;
    font-family: "Yu Mincho", "Hiragino Mincho ProN", serif;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .category-en {
    margin: 3px 0 0;
    color: #e8ca7d;
    font-family: Georgia, serif;
    font-size: 11px;
    letter-spacing: 0.16em;
  }

  .hero-guide {
    position: relative;
    z-index: 2;
    margin: 9px 0 0;
    color: rgba(255,255,255,0.82);
    font-size: 11px;
    letter-spacing: 0.04em;
  }

  /* =========================
     見出し
  ========================= */
  .section-heading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin: 0 0 10px;
    color: #102b4d;
    font-family: "Yu Mincho", "Hiragino Mincho ProN", serif;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .section-heading::before,
  .section-heading::after {
    content: "";
    width: 38px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #c9a84f);
  }

  .section-heading::after {
    background: linear-gradient(90deg, #c9a84f, transparent);
  }

  /* =========================
     問題形式カード
  ========================= */
  .type-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 9px;
  }

  .type-link {
    text-decoration: none;
    display: block;
  }

  .type-card {
    position: relative;
    width: 100%;
    min-height: 88px;
    padding: 9px 8px 12px;
    border: 1px solid #e3e9f0;
    border-radius: 15px;
    background: #fff;
    box-shadow:
      0 7px 18px rgba(20, 52, 88, 0.08),
      inset 0 1px 0 rgba(255,255,255,0.9);
    color: #102b4d;
    text-align: center;
    cursor: pointer;
    overflow: hidden;
    appearance: none;
    -webkit-appearance: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .type-card:active {
    transform: scale(0.98);
  }

  .type-card::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 4px;
    background: linear-gradient(90deg, #b58a27, #f1d985, #b58a27);
  }

  .type-card.active {
    border: 2px solid #d1ad50;
    background: linear-gradient(145deg, #fffdf7, #ffffff);
    box-shadow:
      0 0 0 4px rgba(207, 171, 77, 0.12),
      0 10px 22px rgba(20, 52, 88, 0.12);
  }

  .type-icon {
    width: 34px;
    height: 34px;
    margin: 0 auto 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: linear-gradient(145deg, #fff7d8, #ecd084);
    box-shadow: 0 5px 12px rgba(180, 137, 37, 0.18);
    font-size: 14px;
  }

  .type-title {
    display: block;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .type-en {
    display: block;
    margin-top: 2px;
    color: #a78537;
    font-family: Georgia, serif;
    font-size: 8px;
    letter-spacing: 0.1em;
  }

  /* =========================
     問題数
  ========================= */
  .count-section {
    margin-top: 18px;
    padding: 24px 17px 20px;
    border: 1px solid #dce6f0;
    border-radius: 24px;
    background: rgba(255,255,255,0.72);
    box-shadow:
      0 10px 26px rgba(20, 52, 88, 0.07),
      inset 0 1px 0 rgba(255,255,255,0.95);
  }

  .count-heading {
    margin-bottom: 8px;
  }

  .count-sub {
    margin: 0 0 10px;
    color: #7a8796;
    text-align: center;
    font-size: 11px;
    letter-spacing: 0.05em;
  }

  .illustration-note {
    width: 94%;
    margin: 0 auto 18px;
    padding: 10px 12px;
    border-radius: 12px;
    background: #f4f7fa;
    color: #68788a;
    text-align: center;
    font-size: 11px;
    line-height: 1.55;
  }

  .count-buttons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    width: 100%;
  }

  .count-buttons a {
    display: block;
    text-decoration: none;
  }

  .count-btn {
    position: relative;
    width: 100%;
    height: 82px;
    border: 1px solid #e1e7ee;
    border-radius: 17px;
    background: #fff;
    color: #102b4d;
    font-size: 25px;
    font-weight: 700;
    cursor: pointer;
    overflow: hidden;
    appearance: none;
    -webkit-appearance: none;
    box-shadow: 0 6px 15px rgba(20, 52, 88, 0.08);
  }

  .count-btn::after {
    content: "";
    position: absolute;
    left: 22%;
    right: 22%;
    bottom: 10px;
    height: 3px;
    border-radius: 999px;
    background: linear-gradient(90deg, #b98d2b, #efd782);
  }

  .count-btn:active {
    transform: scale(0.97);
    background: #0c315b;
    color: #f2d889;
  }

  /* =========================
     苦手問題モード
  ========================= */
  .wrong-count-only {
    padding-top: 12px;
  }

  @media (max-width: 390px) {
    .select-page {
      width: 94%;
      padding-top: 14px;
    }

    .category-hero {
      padding: 12px 15px 13px;
    }

    .category-title {
      font-size: 22px;
    }

    .type-card {
      min-height: 84px;
    }

    .type-title {
      font-size: 13px;
    }

    .count-btn {
      height: 76px;
      font-size: 23px;
    }
  }
</style>

<div class="select-page">

  <% unless params[:mode] == "wrong" || params[:category] == "all" %>

    <%
      icon =
        case @category
        when "解剖学"
          "🦴"
        when "生理学"
          "🫀"
        when "運動学"
          "🏃"
        else
          "📘"
        end

      category_en =
        case @category
        when "解剖学"
          "ANATOMY"
        when "生理学"
          "PHYSIOLOGY"
        when "運動学"
          "KINESIOLOGY"
        else
          "NATIONAL EXAM PREP"
        end
    %>

    <section class="category-hero">
      <div class="hero-top-row">
        <p class="category-label">PT NATIONAL EXAM PREP</p>

        <a href="/" class="top-link">
          ← TOP
        </a>
      </div>

      <div class="category-title-wrap">
        <div class="category-icon">
          <%= icon %>
        </div>

        <div>
          <h1 class="category-title"><%= @category %></h1>
          <p class="category-en"><%= category_en %></p>
        </div>
      </div>

      <p class="hero-guide">
        学習する問題形式を選んでください
      </p>
    </section>

    <h2 class="section-heading">
      問題形式を選択
    </h2>

    <div class="type-grid">

      <!-- 全部 -->
      <a
        href="/select?category=<%= @category %>&qtype=all&mode=<%= params[:mode] %>"
        class="type-link"
      >
        <button
          type="button"
          class="type-card <%= 'active' if params[:qtype] == 'all' %>"
        >
          <span class="type-icon">🎲</span>
          <span class="type-title">全部</span>
          <span class="type-en">RANDOM</span>
        </button>
      </a>

      <!-- 5択 -->
      <a
        href="/select?category=<%= @category %>&qtype=choice&mode=<%= params[:mode] %>"
        class="type-link"
      >
        <button
          type="button"
          class="type-card <%= 'active' if params[:qtype] == 'choice' %>"
        >
          <span class="type-icon">▣</span>
          <span class="type-title">5択問題</span>
          <span class="type-en">CHOICE</span>
        </button>
      </a>

      <!-- ○× -->
      <a
        href="/select?category=<%= @category %>&qtype=true_false&mode=<%= params[:mode] %>"
        class="type-link"
      >
        <button
          type="button"
          class="type-card <%= 'active' if params[:qtype] == 'true_false' %>"
        >
          <span class="type-icon">○×</span>
          <span class="type-title">○×問題</span>
          <span class="type-en">TRUE / FALSE</span>
        </button>
      </a>

      <!-- イラスト -->
      <a
        href="/select?category=<%= @category %>&qtype=illustration&mode=<%= params[:mode] %>"
        class="type-link"
      >
        <button
          type="button"
          class="type-card <%= 'active' if params[:qtype] == 'illustration' %>"
        >
          <span class="type-icon">✎</span>
          <span class="type-title">イラスト問題</span>
          <span class="type-en">ILLUSTRATION</span>
        </button>
      </a>

    </div>

  <% end %>


  <!-- ↓ 問題数選択 -->
  <% if params[:qtype].present? || params[:mode] == "wrong" %>

    <section class="count-section <%= 'wrong-count-only' if params[:mode] == 'wrong' %>">

      <h2 class="section-heading count-heading">
        問題数を選択
      </h2>

      <p class="count-sub">
        CHOOSE THE NUMBER OF QUESTIONS
      </p>

      <% if params[:qtype] == "illustration" %>
        <p class="illustration-note">
          ※イラスト問題は自己採点形式です<br>
          ノートや紙に書きながら学習してください
        </p>
      <% end %>

      <div class="count-buttons illustration-count-buttons">

        <a
          href="<%= params[:mode] == 'wrong' ?
            "/questions?mode=wrong&ids=#{params[:ids]}&category=#{params[:category]}&qtype=#{params[:qtype] || 'all'}&count=5&index=0" :
            "/questions?category=#{params[:category]}&qtype=#{params[:qtype]}&count=5"
          %>"
          onclick="localStorage.removeItem('score'); localStorage.removeItem('total');"
        >
          <button type="button" class="count-btn btn-5">
            5問
          </button>
        </a>

        <a
          href="<%= params[:mode] == 'wrong' ?
            "/questions?mode=wrong&ids=#{params[:ids]}&category=#{params[:category]}&qtype=#{params[:qtype] || 'all'}&count=10&index=0" :
            "/questions?category=#{params[:category]}&qtype=#{params[:qtype]}&count=10"
          %>"
          onclick="localStorage.removeItem('score'); localStorage.removeItem('total');"
        >
          <button type="button" class="count-btn btn-10">
            10問
          </button>
        </a>

        <a
          href="<%= params[:mode] == 'wrong' ?
            "/questions?mode=wrong&ids=#{params[:ids]}&category=#{params[:category]}&qtype=#{params[:qtype] || 'all'}&count=15&index=0" :
            "/questions?category=#{params[:category]}&qtype=#{params[:qtype]}&count=15"
          %>"
          onclick="localStorage.removeItem('score'); localStorage.removeItem('total');"
        >
          <button type="button" class="count-btn btn-15">
            15問
          </button>
        </a>

        <a
          href="<%= params[:mode] == 'wrong' ?
            "/questions?mode=wrong&ids=#{params[:ids]}&category=#{params[:category]}&qtype=#{params[:qtype] || 'all'}&count=20&index=0" :
            "/questions?category=#{params[:category]}&qtype=#{params[:qtype]}&count=20"
          %>"
          onclick="localStorage.removeItem('score'); localStorage.removeItem('total');"
        >
          <button type="button" class="count-btn btn-20">
            20問
          </button>
        </a>

      </div>

    </section>

  <% end %>

</div>