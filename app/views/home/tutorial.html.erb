<div class="tutorial-container">
  <%= image_tag "/tutorial/tutorial_#{@page}.png", class: "tutorial-image" %>

  <div class="tutorial-buttons">
    <% if @page > 1 %>
      <%= link_to "← 戻る", "/tutorial?page=#{@page - 1}", class: "back-btn" %>
    <% else %>
      <div></div>
    <% end %>

    <%= link_to "スキップ", root_path, class: "skip-btn" %>

    <% if @page < 5 %>
      <%= link_to "次へ →", "/tutorial?page=#{@page + 1}", class: "next-btn" %>
    <% else %>
      <%= link_to "クイズを始める", root_path, class: "start-btn" %>
    <% end %>
  </div>
</div>

<style>
.tutorial-container{
  max-width:430px;
  margin:40px auto 0;
  text-align:center;
}

.tutorial-image{
  width:100%;
  max-height:68vh;
  object-fit:contain;
  border-radius:20px;
}

.tutorial-buttons{
  margin-top:10px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:10px;
}

.back-btn,
.skip-btn,
.next-btn,
.start-btn{
  background:#d9b24a;
  color:#fff;
  min-width:160px;
  text-align:center;
}

.back-btn{
  background:#666;
  color:#fff;
}

.skip-btn{
  color:#666;
}

.next-btn,
.start-btn{
  background:#d9b24a;
  color:#fff;
}
</style>