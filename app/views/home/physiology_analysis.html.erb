<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
  * {
    box-sizing: border-box;
  }

  body {
    background:
      radial-gradient(circle at 15% 10%, rgba(211, 92, 120, 0.08), transparent 24%),
      linear-gradient(180deg, #f7f9fc 0%, #eef3f9 100%);
  }

  .analysis-page {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    padding: 16px 14px 36px;
    color: #102d52;
  }

  /* =========================
     HERO
  ========================= */
  .analysis-hero {
    position: relative;
    overflow: hidden;
    min-height: 270px;
    padding: 30px 30px 28px;
    border-radius: 0 0 34px 34px;
    background:
      radial-gradient(circle at 85% 25%, rgba(255,255,255,0.10), transparent 24%),
      linear-gradient(135deg, #062b52 0%, #0b467a 62%, #28618d 100%);
    box-shadow: 0 18px 36px rgba(10, 45, 82, 0.20);
  }

  .analysis-hero::before,
  .analysis-hero::after {
    content: "";
    position: absolute;
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 50%;
    pointer-events: none;
  }

  .analysis-hero::before {
    width: 240px;
    height: 240px;
    right: -110px;
    top: -90px;
  }

  .analysis-hero::after {
    width: 180px;
    height: 180px;
    right: -55px;
    bottom: -110px;
  }

  .hero-top {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .hero-brand {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    color: rgba(255,255,255,0.82);
  }

  .top-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 18px;
    border: 1px solid rgba(220, 184, 86, 0.85);
    border-radius: 999px;
    color: #e4c56d;
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    background: rgba(255,255,255,0.03);
  }

  .hero-main {
    position: relative;
    z-index: 2;
    margin-top: 34px;
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .hero-icon {
    width: 76px;
    height: 76px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid rgba(220, 184, 86, 0.75);
    background: rgba(255,255,255,0.06);
    font-size: 34px;
    box-shadow: inset 0 0 24px rgba(255,255,255,0.04);
  }

  .hero-title-wrap {
    min-width: 0;
  }

  .hero-title {
    margin: 0;
    color: white;
    font-size: 36px;
    font-family: "Yu Mincho", "Hiragino Mincho ProN", serif;
    font-weight: 600;
    letter-spacing: 5px;
    line-height: 1.15;
  }

  .hero-en {
    margin-top: 8px;
    color: #e0bd5f;
    font-family: Georgia, serif;
    font-size: 12px;
    letter-spacing: 3px;
  }

  .hero-message {
    position: relative;
    z-index: 2;
    margin: 28px 0 0;
    text-align: center;
    color: rgba(255,255,255,0.88);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1px;
  }

  /* =========================
     SECTION TITLE
  ========================= */
  .section-title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 13px;
    margin: 32px 0 20px;
    color: #102d52;
    font-family: "Yu Mincho", "Hiragino Mincho ProN", serif;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .section-title::before,
  .section-title::after {
    content: "";
    width: 42px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #d35c78);
  }

  .section-title::after {
    background: linear-gradient(90deg, #d35c78, transparent);
  }

  /* =========================
     SUMMARY
  ========================= */
  .summary-card {
    overflow: hidden;
    background: rgba(255,255,255,0.96);
    border: 1px solid rgba(18, 54, 92, 0.08);
    border-radius: 24px;
    box-shadow: 0 12px 28px rgba(17, 48, 82, 0.10);
  }

  .total-area {
    padding: 22px 20px 18px;
    text-align: center;
    background:
      linear-gradient(135deg, rgba(7, 49, 88, 0.035), rgba(211, 92, 120, 0.08));
    border-bottom: 1px solid #edf0f4;
  }

  .total-label {
    color: #6b7890;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .total-number {
    margin-top: 3px;
    color: #102d52;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 45px;
    font-weight: 700;
    line-height: 1;
  }

  .total-number span:last-child {
    margin-left: 5px;
    color: #d35c78;
    font-family: sans-serif;
    font-size: 15px;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 10px;
    padding: 16px;
  }

  .category-item {
    min-width: 0;
    min-height: 82px;
    grid-column: span 2;
    padding: 10px 9px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
    background: #fff;
    border: 1px solid #e8edf3;
    border-radius: 15px;
    box-shadow: 0 4px 12px rgba(19, 49, 83, 0.05);
  }

  .category-item.bottom-left {
    grid-column: 2 / span 2;
  }

  .category-item.bottom-right {
    grid-column: 4 / span 2;
  }

  .category-left {
    min-width: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .category-icon {
    font-size: 23px;
    line-height: 1;
  }

  .category-name {
    margin-top: 5px;
    color: #52647a;
    font-size: 11px;
    font-weight: 700;
    white-space: nowrap;
  }

  .category-name.small {
    font-size: 9px;
    letter-spacing: -0.5px;
  }

  .category-count {
    flex-shrink: 0;
    color: #102d52;
    font-family: Georgia, serif;
    font-size: 21px;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }

  .category-count span:last-child {
    margin-left: 2px;
    color: #7b8795;
    font-family: sans-serif;
    font-size: 10px;
  }

  /* =========================
     WORST AREA
  ========================= */
  .weakest-card {
    margin: 0 16px 18px;
    padding: 1px;
    border-radius: 19px;
    background: linear-gradient(135deg, #bd4765, #ef9aad, #92334e);
  }

  .weakest-inner {
    position: relative;
    overflow: hidden;
    padding: 15px 16px 13px;
    border-radius: 18px;
    text-align: center;
    background:
      radial-gradient(circle at 85% 20%, rgba(255,255,255,0.10), transparent 25%),
      linear-gradient(135deg, #082f59, #124f82);
  }

  .weakest-inner::after {
    content: "";
    position: absolute;
    width: 120px;
    height: 120px;
    right: -60px;
    bottom: -70px;
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 50%;
  }

  .weakest-label {
    position: relative;
    z-index: 2;
    color: #f1a4b5;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .weakest-title {
    position: relative;
    z-index: 2;
    margin-top: 7px;
    color: white;
    font-size: 18px;
    font-weight: 700;
  }

  .weakest-tip {
    position: relative;
    z-index: 2;
    margin-top: 9px;
    padding-top: 9px;
    border-top: 1px solid rgba(255,255,255,0.14);
    color: rgba(255,255,255,0.68);
    font-size: 11px;
  }

  /* =========================
     CHART
  ========================= */
  .chart-card {
    margin-top: 18px;
    padding: 20px 14px 14px;
    background: rgba(255,255,255,0.96);
    border: 1px solid rgba(18, 54, 92, 0.08);
    border-radius: 24px;
    box-shadow: 0 12px 28px rgba(17, 48, 82, 0.10);
  }

  .chart-heading {
    text-align: center;
  }

  .chart-kicker {
    color: #d35c78;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .chart-title {
    margin-top: 4px;
    color: #102d52;
    font-family: "Yu Mincho", "Hiragino Mincho ProN", serif;
    font-size: 21px;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .chart-wrap {
    height: 350px;
    margin-top: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .chart-note {
    margin: 4px 5px 0;
    padding-top: 10px;
    border-top: 1px solid #edf0f4;
    text-align: center;
    color: #8a94a1;
    font-size: 10px;
  }

  @media (max-width: 420px) {
    .analysis-page {
      padding: 6px 10px 24px;
    }

    .analysis-hero {
      min-height: 145px;
      padding: 15px 18px 14px;
      border-radius: 0 0 26px 26px;
    }

    .hero-brand {
      font-size: 8px;
      letter-spacing: 1.8px;
    }

    .top-button {
      padding: 6px 12px;
      font-size: 9px;
    }

    .hero-main {
      margin-top: 13px;
      gap: 11px;
    }

    .hero-icon {
      width: 48px;
      height: 48px;
      font-size: 23px;
    }

    .hero-title {
      font-size: 27px;
      letter-spacing: 3px;
    }

    .hero-en {
      margin-top: 3px;
      font-size: 8px;
      letter-spacing: 1.8px;
    }

    .hero-message {
      margin: 10px 0 0;
      font-size: 10px;
      letter-spacing: 0;
      white-space: nowrap;
    }

    .section-title {
      margin: 17px 0 12px;
      font-size: 20px;
      gap: 10px;
    }

    .section-title::before,
    .section-title::after {
      width: 28px;
    }

    .total-area {
      padding: 12px 16px 10px;
    }

    .total-label {
      font-size: 9px;
      letter-spacing: 1.7px;
    }

  .total-number {
  margin-top: 2px;
  font-family: sans-serif;
  font-size: 16px;
  font-weight: 700;
}

    .total-number span:last-child {
      font-size: 12px;
    }

    .category-grid {
      gap: 7px;
      padding: 10px;
    }

    .category-item {
      min-height: 64px;
      padding: 7px;
      gap: 3px;
      border-radius: 12px;
    }

    .category-icon {
      font-size: 18px;
    }

    .category-name {
      margin-top: 3px;
      font-size: 9px;
    }

    .category-name.small {
      font-size: 7px;
      letter-spacing: -0.7px;
    }

    .category-count {
      font-size: 15px;
    }

    .category-count span:last-child {
      font-size: 8px;
    }

    .weakest-card {
      margin: 0 10px 10px;
      border-radius: 15px;
    }

    .weakest-inner {
      padding: 9px 12px 8px;
      border-radius: 14px;
    }

    .weakest-label {
      font-size: 8px;
      letter-spacing: 1.6px;
    }

    .weakest-title {
      margin-top: 4px;
      font-size: 14px;
    }

    .weakest-tip {
      margin-top: 5px;
      padding-top: 5px;
      font-size: 9px;
    }

    .chart-card {
      margin-top: 10px;
      padding: 14px 10px 10px;
    }

    .chart-kicker {
      font-size: 8px;
    }

    .chart-title {
      margin-top: 2px;
      font-size: 18px;
    }

    .chart-wrap {
      height: 315px;
      margin-top: 4px;
    }
  }
</style>


<div class="analysis-page">

  <section class="analysis-hero">

    <div class="hero-top">
      <div class="hero-brand">PT NATIONAL EXAM PREP</div>

      <%= link_to root_path, class: "top-button" do %>
        ← TOP
      <% end %>
    </div>


    <div class="hero-main">

      <div class="hero-icon">🫀</div>

      <div class="hero-title-wrap">
        <h1 class="hero-title">生理学</h1>
        <div class="hero-en">WEAKNESS ANALYSIS</div>
      </div>

    </div>


    <p class="hero-message">
      苦手を「見える化」して、効率的に克服しよう
    </p>

  </section>


  <div class="section-title">
    苦手分析
  </div>


  <section class="summary-card">

    <div class="total-area">

      <div class="total-label">
        TOTAL WEAK QUESTIONS
      </div>

      <div class="total-number">
        <span id="physiology-total">0</span><span>問</span>
      </div>

    </div>


    <div class="category-grid">

      <div class="category-item">
        <div class="category-left">
          <div class="category-icon">🧠</div>
          <div class="category-name">神経生理</div>
        </div>
        <div class="category-count">
          <span id="nerve-physiology-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item">
        <div class="category-left">
          <div class="category-icon">💪</div>
          <div class="category-name">筋生理</div>
        </div>
        <div class="category-count">
          <span id="muscle-physiology-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item">
        <div class="category-left">
          <div class="category-icon">🫀</div>
          <div class="category-name">循環</div>
        </div>
        <div class="category-count">
          <span id="circulation-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item">
        <div class="category-left">
          <div class="category-icon">🫁</div>
          <div class="category-name">呼吸</div>
        </div>
        <div class="category-count">
          <span id="respiration-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item">
        <div class="category-left">
          <div class="category-icon">🩺</div>
          <div class="category-name">内臓</div>
        </div>
        <div class="category-count">
          <span id="organ-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item">
        <div class="category-left">
          <div class="category-icon">🧪</div>
          <div class="category-name">ホルモン</div>
        </div>
        <div class="category-count">
          <span id="hormone-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item bottom-left">
        <div class="category-left">
          <div class="category-icon">🍚</div>
          <div class="category-name">消化</div>
        </div>
        <div class="category-count">
          <span id="digestion-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item bottom-right">
        <div class="category-left">
          <div class="category-icon">🌡️</div>
          <div class="category-name small">体温・恒常性</div>
        </div>
        <div class="category-count">
          <span id="homeostasis-count">0</span><span>問</span>
        </div>
      </div>

    </div>


    <div id="weakest-area"></div>

  </section>


  <section class="chart-card">

    <div class="chart-heading">

      <div class="chart-kicker">
        WEAKNESS BALANCE
      </div>

      <div class="chart-title">
        分野別 苦手度チャート
      </div>

    </div>


    <div class="chart-wrap">
      <canvas id="radarChart"></canvas>
    </div>


    <p class="chart-note">
      ※ レーダーチャートは5択・○×問題のみ集計しています
    </p>

  </section>

</div>


<script>
const wrong = JSON.parse(localStorage.getItem("wrong")) || []

let physiology = 0

let nervePhysiology = 0
let musclePhysiology = 0
let circulation = 0
let respiration = 0
let organ = 0
let hormone = 0
let digestion = 0
let homeostasis = 0


wrong.forEach(q => {

  if(q.category === "生理") physiology++

  if(q.subcategory === "神経生理") nervePhysiology++
  if(q.subcategory === "筋生理") musclePhysiology++
  if(q.subcategory === "循環") circulation++
  if(q.subcategory === "呼吸") respiration++
  if(q.subcategory === "内臓") organ++
  if(q.subcategory === "ホルモン") hormone++
  if(q.subcategory === "消化") digestion++
  if(q.subcategory === "体温・恒常性") homeostasis++

})


document.getElementById("physiology-total").textContent = physiology
document.getElementById("nerve-physiology-count").textContent = nervePhysiology
document.getElementById("muscle-physiology-count").textContent = musclePhysiology
document.getElementById("circulation-count").textContent = circulation
document.getElementById("respiration-count").textContent = respiration
document.getElementById("organ-count").textContent = organ
document.getElementById("hormone-count").textContent = hormone
document.getElementById("digestion-count").textContent = digestion
document.getElementById("homeostasis-count").textContent = homeostasis


const weakAreas = [
  { name: "神経生理", count: nervePhysiology },
  { name: "筋生理", count: musclePhysiology },
  { name: "循環", count: circulation },
  { name: "呼吸", count: respiration },
  { name: "内臓", count: organ },
  { name: "ホルモン", count: hormone },
  { name: "消化", count: digestion },
  { name: "体温・恒常性", count: homeostasis }
]


const maxWeak = Math.max(...weakAreas.map(a => a.count))


if (maxWeak > 0) {

  const topWeak = weakAreas.filter(a => a.count === maxWeak)

  let weakestText = ""

  if (topWeak.length === 1) {
    weakestText = `${topWeak[0].name}（${topWeak[0].count}問）`
  } else {
    weakestText = `${topWeak.map(a => a.name).join("・")}（各${maxWeak}問）`
  }

  document.getElementById("weakest-area").innerHTML = `
    <div class="weakest-card">

      <div class="weakest-inner">

        <div class="weakest-label">
          MOST DIFFICULT AREA
        </div>

        <div class="weakest-title">
          🥇 一番苦手：${weakestText}
        </div>

        <div class="weakest-tip">
          💡 次に勉強すると効果的！
        </div>

      </div>

    </div>
  `
}


const ctx = document.getElementById("radarChart")


new Chart(ctx, {

  type: "radar",

  data: {

    labels: [
      "神経生理",
      "筋生理",
      "循環",
      "呼吸",
      "内臓",
      "ホルモン",
      "消化",
      "体温"
    ],

    datasets: [{

      label: "苦手問題数",

      data: [
        nervePhysiology,
        musclePhysiology,
        circulation,
        respiration,
        organ,
        hormone,
        digestion,
        homeostasis
      ],

      borderColor: "#d35c78",
      backgroundColor: "rgba(211, 92, 120, 0.18)",
      pointBackgroundColor: "#0b467a",
      pointBorderColor: "#ffffff",
      pointBorderWidth: 2,
      pointRadius: 5,
      borderWidth: 3

    }]

  },


  options: {

    responsive: true,
    maintainAspectRatio: false,

    plugins: {

      legend: {
        display: false
      }

    },

    scales: {

      r: {

        beginAtZero: true,

        angleLines: {
          color: "rgba(16, 45, 82, 0.12)"
        },

        grid: {
          color: "rgba(16, 45, 82, 0.12)"
        },

        pointLabels: {

          color: "#52647a",

          font: {
            size: 11,
            weight: "bold"
          }

        },

        ticks: {

          stepSize: 1,
          color: "#8995a5",
          backdropColor: "transparent",

          font: {
            size: 10
          }

        }

      }

    }

  }

})
</script>