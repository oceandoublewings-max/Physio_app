<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
  * {
    box-sizing: border-box;
  }

  body {
    background:
      radial-gradient(circle at 15% 10%, rgba(44, 111, 201, 0.08), transparent 24%),
      linear-gradient(180deg, #f7f9fc 0%, #eef3f9 100%);
  }

  .analysis-page {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    padding: 16px 14px 36px;
    color: #102d52;
  }

  /* =========================
     HERO
  ========================= */
  .analysis-hero {
    position: relative;
    overflow: hidden;
    min-height: 270px;
    padding: 30px 30px 28px;
    border-radius: 0 0 34px 34px;
    background:
      radial-gradient(circle at 85% 25%, rgba(255,255,255,0.10), transparent 24%),
      linear-gradient(135deg, #062b52 0%, #0b467a 62%, #28618d 100%);
    box-shadow: 0 18px 36px rgba(10, 45, 82, 0.20);
  }

  .analysis-hero::before,
  .analysis-hero::after {
    content: "";
    position: absolute;
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 50%;
    pointer-events: none;
  }

  .analysis-hero::before {
    width: 240px;
    height: 240px;
    right: -110px;
    top: -90px;
  }

  .analysis-hero::after {
    width: 180px;
    height: 180px;
    right: -55px;
    bottom: -110px;
  }

  .hero-top {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .hero-brand {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    color: rgba(255,255,255,0.82);
  }

  .top-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 18px;
    border: 1px solid rgba(220, 184, 86, 0.85);
    border-radius: 999px;
    color: #e4c56d;
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    background: rgba(255,255,255,0.03);
  }

  .hero-main {
    position: relative;
    z-index: 2;
    margin-top: 34px;
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .hero-icon {
    width: 76px;
    height: 76px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid rgba(220, 184, 86, 0.75);
    background: rgba(255,255,255,0.06);
    font-size: 34px;
    box-shadow: inset 0 0 24px rgba(255,255,255,0.04);
  }

  .hero-title-wrap {
    min-width: 0;
  }

  .hero-title {
    margin: 0;
    color: white;
    font-size: 36px;
    font-family: "Yu Mincho", "Hiragino Mincho ProN", serif;
    font-weight: 600;
    letter-spacing: 5px;
    line-height: 1.15;
  }

  .hero-en {
    margin-top: 8px;
    color: #e0bd5f;
    font-family: Georgia, serif;
    font-size: 12px;
    letter-spacing: 3px;
  }

  .hero-message {
    position: relative;
    z-index: 2;
    margin: 28px 0 0;
    text-align: center;
    color: rgba(255,255,255,0.88);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1px;
  }

  /* =========================
     SECTION TITLE
  ========================= */
  .section-title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 13px;
    margin: 32px 0 20px;
    color: #102d52;
    font-family: "Yu Mincho", "Hiragino Mincho ProN", serif;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .section-title::before,
  .section-title::after {
    content: "";
    width: 42px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #2d6fc9);
  }

  .section-title::after {
    background: linear-gradient(90deg, #2d6fc9, transparent);
  }

  /* =========================
     SUMMARY
  ========================= */
  .summary-card {
    overflow: hidden;
    background: rgba(255,255,255,0.96);
    border: 1px solid rgba(18, 54, 92, 0.08);
    border-radius: 24px;
    box-shadow: 0 12px 28px rgba(17, 48, 82, 0.10);
  }

  .total-area {
    padding: 22px 20px 18px;
    text-align: center;
    background:
      linear-gradient(135deg, rgba(7, 49, 88, 0.035), rgba(45, 111, 201, 0.08));
    border-bottom: 1px solid #edf0f4;
  }

  .total-label {
    color: #6b7890;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .total-number {
    margin-top: 3px;
    color: #102d52;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 45px;
    font-weight: 700;
    line-height: 1;
  }

  .total-number span:last-child {
    margin-left: 5px;
    color: #2d6fc9;
    font-family: sans-serif;
    font-size: 15px;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    padding: 16px;
  }

  .category-item {
    min-width: 0;
    padding: 13px 5px 11px;
    text-align: center;
    background: #fff;
    border: 1px solid #e8edf3;
    border-radius: 15px;
    box-shadow: 0 4px 12px rgba(19, 49, 83, 0.05);
  }

  .category-icon {
    font-size: 23px;
    line-height: 1;
  }

  .category-name {
    margin-top: 6px;
    color: #52647a;
    font-size: 11px;
    font-weight: 700;
    white-space: nowrap;
  }

  .category-name.small {
    font-size: 9px;
    letter-spacing: -0.5px;
  }

  .category-count {
    margin-top: 2px;
    color: #102d52;
    font-family: Georgia, serif;
    font-size: 23px;
    font-weight: 700;
    line-height: 1.1;
  }

  .category-count span:last-child {
    margin-left: 2px;
    color: #7b8795;
    font-family: sans-serif;
    font-size: 10px;
  }

  .category-item.last-item {
    grid-column: 2;
  }

  /* =========================
     WORST AREA
  ========================= */
  .weakest-card {
    margin: 0 16px 18px;
    padding: 1px;
    border-radius: 19px;
    background: linear-gradient(135deg, #2d6fc9, #77b4ff, #164e9d);
  }

  .weakest-inner {
    position: relative;
    overflow: hidden;
    padding: 19px 16px 17px;
    border-radius: 18px;
    text-align: center;
    background:
      radial-gradient(circle at 85% 20%, rgba(255,255,255,0.10), transparent 25%),
      linear-gradient(135deg, #082f59, #124f82);
  }

  .weakest-inner::after {
    content: "";
    position: absolute;
    width: 120px;
    height: 120px;
    right: -60px;
    bottom: -70px;
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 50%;
  }

  .weakest-label {
    position: relative;
    z-index: 2;
    color: #78b7ff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .weakest-title {
    position: relative;
    z-index: 2;
    margin-top: 5px;
    color: white;
    font-size: 18px;
    font-weight: 700;
  }

  .weakest-list {
    position: relative;
    z-index: 2;
    margin-top: 9px;
    color: white;
    font-size: 15px;
    font-weight: 600;
    line-height: 1.7;
  }

  .weakest-tip {
    position: relative;
    z-index: 2;
    margin-top: 9px;
    padding-top: 9px;
    border-top: 1px solid rgba(255,255,255,0.14);
    color: rgba(255,255,255,0.68);
    font-size: 11px;
  }

  /* =========================
     CHART
  ========================= */
  .chart-card {
    margin-top: 18px;
    padding: 20px 14px 14px;
    background: rgba(255,255,255,0.96);
    border: 1px solid rgba(18, 54, 92, 0.08);
    border-radius: 24px;
    box-shadow: 0 12px 28px rgba(17, 48, 82, 0.10);
  }

  .chart-heading {
    text-align: center;
  }

  .chart-kicker {
    color: #2d6fc9;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .chart-title {
    margin-top: 4px;
    color: #102d52;
    font-family: "Yu Mincho", "Hiragino Mincho ProN", serif;
    font-size: 21px;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .chart-wrap {
    height: 350px;
    margin-top: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .chart-note {
    margin: 4px 5px 0;
    padding-top: 10px;
    border-top: 1px solid #edf0f4;
    text-align: center;
    color: #8a94a1;
    font-size: 10px;
  }

  @media (max-width: 420px) {
    .analysis-page {
      padding: 10px 10px 28px;
    }

    .analysis-hero {
      min-height: 250px;
      padding: 26px 22px 24px;
    }

    .hero-brand {
      font-size: 9px;
      letter-spacing: 2px;
    }

    .top-button {
      padding: 8px 14px;
      font-size: 10px;
    }

    .hero-main {
      margin-top: 31px;
      gap: 15px;
    }

    .hero-icon {
      width: 67px;
      height: 67px;
      font-size: 30px;
    }

    .hero-title {
      font-size: 32px;
      letter-spacing: 4px;
    }

    .hero-en {
      font-size: 10px;
      letter-spacing: 2px;
    }

    .hero-message {
      margin-top: 26px;
      font-size: 13px;
    }

    .section-title {
      margin: 28px 0 17px;
      font-size: 22px;
    }

    .section-title::before,
    .section-title::after {
      width: 30px;
    }

    .category-grid {
      gap: 8px;
      padding: 13px;
    }

    .category-item {
      padding: 12px 3px 10px;
    }

    .category-name {
      font-size: 10px;
    }

    .category-name.small {
      font-size: 8px;
    }

    .category-count {
      font-size: 21px;
    }

    .chart-wrap {
      height: 330px;
    }
  }
</style>


<div class="analysis-page">

  <section class="analysis-hero">

    <div class="hero-top">
      <div class="hero-brand">PT NATIONAL EXAM PREP</div>

      <%= link_to root_path, class: "top-button" do %>
        ← TOP
      <% end %>
    </div>


    <div class="hero-main">

      <div class="hero-icon">🏃</div>

      <div class="hero-title-wrap">
        <h1 class="hero-title">運動学</h1>
        <div class="hero-en">WEAKNESS ANALYSIS</div>
      </div>

    </div>


    <p class="hero-message">
      苦手を「見える化」して、効率的に克服しよう
    </p>

  </section>


  <div class="section-title">
    苦手分析
  </div>


  <section class="summary-card">

    <div class="total-area">

      <div class="total-label">
        TOTAL WEAK QUESTIONS
      </div>

      <div class="total-number">
        <span id="kinesiology-total">0</span><span>問</span>
      </div>

    </div>


    <div class="category-grid">

      <div class="category-item">
        <div class="category-icon">🦴</div>
        <div class="category-name">関節運動</div>
        <div class="category-count">
          <span id="joint-motion-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item">
        <div class="category-icon">📏</div>
        <div class="category-name">ROM</div>
        <div class="category-count">
          <span id="rom-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item">
        <div class="category-icon">💪</div>
        <div class="category-name">筋作用</div>
        <div class="category-count">
          <span id="muscle-action-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item">
        <div class="category-icon">🚶</div>
        <div class="category-name">歩行</div>
        <div class="category-count">
          <span id="gait-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item">
        <div class="category-icon">🧍</div>
        <div class="category-name">姿勢</div>
        <div class="category-count">
          <span id="posture-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item">
        <div class="category-icon">⚙️</div>
        <div class="category-name small">バイオメカニズム</div>
        <div class="category-count">
          <span id="biomechanics-count">0</span><span>問</span>
        </div>
      </div>

      <div class="category-item last-item">
        <div class="category-icon">🎥</div>
        <div class="category-name">動作分析</div>
        <div class="category-count">
          <span id="movement-analysis-count">0</span><span>問</span>
        </div>
      </div>

    </div>


    <div id="weakest-area"></div>

  </section>


  <section class="chart-card">

    <div class="chart-heading">
      <div class="chart-kicker">
        WEAKNESS BALANCE
      </div>

      <div class="chart-title">
        分野別 苦手度チャート
      </div>
    </div>


    <div class="chart-wrap">
      <canvas id="radarChart"></canvas>
    </div>


    <p class="chart-note">
      ※ レーダーチャートは5択・○×問題のみ集計しています
    </p>

  </section>

</div>


<script>
const wrong = JSON.parse(localStorage.getItem("wrong")) || []

let kinesiology = 0

let jointMotion = 0
let rom = 0
let muscleAction = 0
let gait = 0
let posture = 0
let biomechanics = 0
let movementAnalysis = 0


wrong.forEach(q => {

  if(q.category === "運動") kinesiology++

  if(q.subcategory === "関節運動") jointMotion++
  if(q.subcategory === "ROM") rom++
  if(q.subcategory === "筋作用") muscleAction++
  if(q.subcategory === "歩行") gait++
  if(q.subcategory === "姿勢") posture++
  if(q.subcategory === "バイオメカニズム") biomechanics++
  if(q.subcategory === "動作分析") movementAnalysis++

})


document.getElementById("kinesiology-total").textContent = kinesiology
document.getElementById("joint-motion-count").textContent = jointMotion
document.getElementById("rom-count").textContent = rom
document.getElementById("muscle-action-count").textContent = muscleAction
document.getElementById("gait-count").textContent = gait
document.getElementById("posture-count").textContent = posture
document.getElementById("biomechanics-count").textContent = biomechanics
document.getElementById("movement-analysis-count").textContent = movementAnalysis


const weakAreas = [
  { name: "関節運動", icon: "🦴", count: jointMotion },
  { name: "ROM", icon: "📏", count: rom },
  { name: "筋作用", icon: "💪", count: muscleAction },
  { name: "歩行", icon: "🚶", count: gait },
  { name: "姿勢", icon: "🧍", count: posture },
  { name: "バイオメカニズム", icon: "⚙️", count: biomechanics },
  { name: "動作分析", icon: "🎥", count: movementAnalysis }
]


const maxWeak = Math.max(...weakAreas.map(a => a.count))


if (maxWeak > 0) {

  const topWeak = weakAreas.filter(a => a.count === maxWeak)

  document.getElementById("weakest-area").innerHTML = `
    <div class="weakest-card">

      <div class="weakest-inner">

        <div class="weakest-label">
          MOST DIFFICULT AREA
        </div>

        <div class="weakest-title">
          🥇 一番苦手：${topWeak.map(a => a.name).join("・")}
        </div>

        <div class="weakest-list">
          ${topWeak.map(a => `${a.icon} ${a.name}（${a.count}問）`).join("<br>")}
        </div>

        <div class="weakest-tip">
          💡 次に勉強すると効果的！
        </div>

      </div>

    </div>
  `
}


const ctx = document.getElementById("radarChart")


new Chart(ctx, {

  type: "radar",

  data: {

    labels: [
      "関節運動",
      "ROM",
      "筋作用",
      "歩行",
      "姿勢",
      "バイオ",
      "動作分析"
    ],

    datasets: [{

      label: "苦手問題数",

      data: [
        jointMotion,
        rom,
        muscleAction,
        gait,
        posture,
        biomechanics,
        movementAnalysis
      ],

      borderColor: "#2d6fc9",
      backgroundColor: "rgba(45, 111, 201, 0.18)",
      pointBackgroundColor: "#0b467a",
      pointBorderColor: "#ffffff",
      pointBorderWidth: 2,
      pointRadius: 5,
      borderWidth: 3

    }]

  },


  options: {

    responsive: true,
    maintainAspectRatio: false,

    plugins: {

      legend: {
        display: false
      }

    },

    scales: {

      r: {

        beginAtZero: true,

        angleLines: {
          color: "rgba(16, 45, 82, 0.12)"
        },

        grid: {
          color: "rgba(16, 45, 82, 0.12)"
        },

        pointLabels: {

          color: "#52647a",

          font: {
            size: 11,
            weight: "bold"
          }

        },

        ticks: {

          stepSize: 1,
          color: "#8995a5",
          backdropColor: "transparent",

          font: {
            size: 10
          }

        }

      }

    }

  }

})
</script>