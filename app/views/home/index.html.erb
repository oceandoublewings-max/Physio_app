</a>
`;

console.log("OK")

function goWrongAll() {

  const wrong = JSON.parse(localStorage.getItem("wrong")) || [];

  const filtered = wrong.map(q => q.id);

  if (filtered.length === 0) {
  alert("苦手問題はありません");
  return;
}

  window.location.href =
    "/select?mode=wrong" +
    "&ids=" + encodeURIComponent(filtered.join(",")) +
