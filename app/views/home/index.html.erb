        苦手を「見える化」して、効率的に克服しよう
      </p>

      <div id="analysis-box"></div>

    </section>


    <!-- =========================
         下部リンク
    ========================= -->
    <div class="bottom-links">

      <%= link_to "/materials", class: "bottom-link" do %>
        <span class="bottom-icon">📚</span>
        <span class="bottom-title"><%= current_user&.guest? ? "🔒 参考資料" : "参考資料" %></span>
        <span class="bottom-note">重要ポイントを整理</span>
      <% end %>


      <%= link_to "/stamps", class: "bottom-link" do %>
        <span class="bottom-icon">🏅</span>
        <span class="bottom-title"><%= current_user&.guest? ? "🔒 図鑑" : "図鑑" %></span>
        <span class="bottom-note">イラストで理解を深める</span>
      <% end %>


      <%= link_to "/contact", class: "bottom-link" do %>
        <span class="bottom-icon">✉️</span>
        <span class="bottom-title"><%= current_user&.guest? ? "🔒 問合せ" : "問合せ" %></span>
        <span class="bottom-note">サポートに連絡する</span>
      <% end %>

    </div>

  </main>

</div>


<script>
  const wrong = JSON.parse(localStorage.getItem("wrong")) || [];

  let anatomy = 0;
  let physiology = 0;
  let kinesiology = 0;

  wrong.forEach(q => {
    if (q.category === "解剖") anatomy++;
    if (q.category === "生理") physiology++;
    if (q.category === "運動") kinesiology++;
  });


  document.getElementById("analysis-box").innerHTML = `

    <div class="analysis-grid">

      <a href="/anatomy_analysis"
         class="analysis-card">

        <div class="analysis-label">
          🦴 解剖学
        </div>

        <div class="analysis-number">
          ${anatomy}<small>問</small>
        </div>

        <div class="mini-bar">
          <div class="mini-bar-fill bar-anatomy"></div>
        </div>

      </a>


      <a href="/physiology_analysis"
         class="analysis-card">

        <div class="analysis-label">
          🫀 生理学
        </div>

        <div class="analysis-number">
          ${physiology}<small>問</small>
        </div>

        <div class="mini-bar">
          <div class="mini-bar-fill bar-physiology"></div>
        </div>

      </a>


      <a href="/kinesiology_analysis"
         class="analysis-card">

        <div class="analysis-label">
          🏃 運動学
        </div>

        <div class="analysis-number">
          ${kinesiology}<small>問</small>
        </div>

        <div class="mini-bar">
          <div class="mini-bar-fill bar-kinesiology"></div>
        </div>

      </a>

    </div>


    <button
      type="button"
      class="wrong-all-button"
      onclick="goWrongAll()">

      🔥 苦手問題（全範囲） 〉

    </button>

    <p class="wrong-all-note">
      全分野の苦手問題をまとめて解く
    </p>
  `;



  // =========================
  // 効果音設定
  // =========================
  const soundSettingsButton =
    document.getElementById("sound-settings-button");

  const soundSettingsPanel =
    document.getElementById("sound-settings-panel");

  const soundOptions =
    document.querySelectorAll(".sound-option");

  function getSoundSetting() {
    return localStorage.getItem("soundEnabled") || "off";
  }

  function updateSoundButtons() {
    const currentSetting = getSoundSetting();

    soundOptions.forEach(button => {
      button.classList.toggle(
        "is-active",
        button.dataset.sound === currentSetting
      );
    });
  }

  soundSettingsButton.addEventListener("click", function(event) {
    event.stopPropagation();

    const isOpen =
      document.getElementById("settings-overlay").classList.toggle("is-open");
    soundSettingsPanel.classList.toggle("is-open");

    soundSettingsButton.setAttribute(
      "aria-expanded",
      isOpen ? "true" : "false"
    );
  });

  soundOptions.forEach(button => {
    button.addEventListener("click", function() {
      localStorage.setItem(
        "soundEnabled",
        this.dataset.sound
      );

      updateSoundButtons();

      document.getElementById("settings-overlay").classList.remove("is-open");
      soundSettingsPanel.classList.remove("is-open");
      soundSettingsButton.setAttribute("aria-expanded", "false");
    });
  });

  document.addEventListener("click", function(event) {
    if (!document.getElementById("sound-settings").contains(event.target)) {
      document.getElementById("settings-overlay").classList.remove("is-open");
      soundSettingsPanel.classList.remove("is-open");
      soundSettingsButton.setAttribute("aria-expanded", "false");
    }
  });

  updateSoundButtons();


  function goWrongAll() {

    const wrong =
      JSON.parse(localStorage.getItem("wrong")) || [];

    const filtered =
      wrong.map(q => q.id);

    if (filtered.length === 0) {
      alert("苦手問題はありません");
      return;
    }

    window.location.href =
      "/select?mode=wrong" +
      "&ids=" + encodeURIComponent(filtered.join(",")) +
      "&category=all";
  }
</script>
