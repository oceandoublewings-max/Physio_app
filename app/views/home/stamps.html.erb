<h1 style="text-align:center;">
🏅 スタンプ図鑑
</h1>

<div style="
width:120px;
height:120px;
margin:40px auto;
border:2px solid #ccc;
border-radius:10px;
background:white;
display:flex;
align-items:center;
justify-content:center;
">

  <%= image_tag "stamps/stamp_001.png",
      style: "width:100%; height:100%; object-fit:contain;" %>

</div>

<h2 style="text-align:center; margin-top:40px;">
🎃 期間限定スタンプ
</h2>

<p style="text-align:center; color:#888;">
準備中
</p>

<div style="
display:grid;
grid-template-columns:repeat(5,1fr);
gap:10px;
max-width:500px;
margin:20px auto;
">

<% 10.times do %>
  <div style="
    aspect-ratio:1;
    border:2px dashed #ccc;
    border-radius:10px;
    background:#f8f8f8;
  "></div>
<% end %>

</div>