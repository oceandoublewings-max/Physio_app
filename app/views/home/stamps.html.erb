<h1 style="text-align:center;">
  🏅 スタンプ図鑑
</h1>

<p style="
  text-align:center;
  color:#666;
  font-size:15px;
  margin-bottom:25px;
  line-height:1.7;
">
💀 問題を解いてスタンプGET！<br>
コンプリート目指して頑張ろう✨
</p>

<div style="
display:grid;
grid-template-columns:repeat(5,1fr);
gap:10px;
max-width:520px;
margin:0 auto;
padding:10px;
">

<% (1..100).each do |i| %>

<% file = "stamps/stamp_%03d.png" % i %>

<div style="
aspect-ratio:1;
border:2px solid #ddd;
border-radius:12px;
background:#fafafa;
display:flex;
justify-content:center;
align-items:center;
position:relative;
overflow:hidden;
">

<% if File.exist?(Rails.root.join("public","images",file)) %>

<%= image_tag "/images/#{file}",
style:"width:85%;height:85%;object-fit:contain;cursor:pointer;",
onclick:"openStamp('/images/#{file}')"
%>

<% else %>

<span style="
font-size:28px;
color:#c8d5e6;
font-weight:bold;
">
<%= "%03d" % i %>
</span>

<% end %>

</div>

<% end %>

</div>

<hr style="
margin:50px auto 30px;
max-width:520px;
border:none;
border-top:2px solid #eee;
">

<div style="text-align:center; margin-bottom:40px;">

<%= link_to "🎉 イベントスタンプ図鑑はこちら ▶",
event_stamps_path,
style:"
display:inline-block;
padding:12px 24px;
background:#ff9800;
color:white;
text-decoration:none;
border-radius:12px;
font-weight:bold;
font-size:16px;
" %>

</div>

<div id="stampModal"
onclick="closeStamp()"
style="
display:none;
position:fixed;
inset:0;
background:rgba(0,0,0,.7);
justify-content:center;
align-items:center;
z-index:9999;
">

<img id="stampImage"
style="
max-width:80%;
max-height:75%;
background:white;
border-radius:20px;
padding:20px;
">

</div>

<script>
function openStamp(src){
  document.getElementById("stampImage").src = src;
  document.getElementById("stampModal").style.display = "flex";
}

function closeStamp(){
  document.getElementById("stampModal").style.display = "none";
}
</script>