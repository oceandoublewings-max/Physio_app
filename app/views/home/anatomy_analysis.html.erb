<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div style="
  max-width: 700px;
  margin:5px auto 15px;
  text-align: center;
">

 <h1 style="
  font-size:24px;
  margin-top:0;
  margin-bottom:10px;
">
    🦴 解剖学 苦手分析
  </h1>

  <div id="anatomy-box" style="
    background: white;
    padding: 10px 16px;
    border-radius: 18px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    font-size: 18px;
    font-weight: bold;
    line-height: 1.6;
  ">
  </div>

</div>

<div style="
  margin-top: 12px;
  background: white;
 padding:16px;
  border-radius: 18px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
">

 
 <h2 style="
  font-size:18px;
  margin-bottom:10px;
">
  ⭐ 分野別 苦手度チャート
</h2>

  <div style="
    height:360px;
    display:flex;
    justify-content:center;
    align-items:center;
    color:#999;
    border-radius:12px;
  ">
    <canvas id="radarChart"></canvas>
  </div>
<p style="
  text-align:right;
  font-size:11px;
  color:#888;
  margin-top:8px;
  margin-bottom:0;
  padding-right:8px;
">
  ※ レーダーチャートは5択・○×問題のみ集計しています
</p>

</div>

<script>
const wrong = JSON.parse(localStorage.getItem("wrong")) || []

let anatomy = 0

let bone = 0
let muscle = 0
let nerve = 0
let organ = 0
let vessel = 0
let position = 0

wrong.forEach(q => {

  if(q.category === "解剖") anatomy++

  if(q.subcategory === "骨") bone++
  if(q.subcategory === "筋肉") muscle++
  if(q.subcategory === "神経") nerve++
  if(q.subcategory === "臓器") organ++
  if(q.subcategory === "血管") vessel++
  if(q.subcategory === "断面・位置関係") position++

})

const weakAreas = [
  { name: "骨", icon: "🦴", count: bone },
  { name: "筋肉", icon: "💪", count: muscle },
  { name: "神経", icon: "🧠", count: nerve },
  { name: "臓器", icon: "🫀", count: organ },
  { name: "血管", icon: "🩸", count: vessel },
  { name: "断面・位置関係", icon: "📍", count: position }
];

const maxWeak = Math.max(...weakAreas.map(a => a.count));

let weakMessage = "";

if (maxWeak > 0) {
  const topWeak = weakAreas.filter(a => a.count === maxWeak);

  weakMessage = `
  <div style="
    margin-top:16px;
    padding:14px;
    background:#F8FBFF;
    border:1px solid #D6E8FF;
    border-radius:12px;
    text-align:center;
  ">

    <div style="
      font-size:18px;
      font-weight:bold;
    ">
      🥇 一番苦手：${topWeak.map(a => a.name).join("・")}
    </div>

    <div style="
      margin-top:8px;
      font-size:16px;
    ">
      ${topWeak.map(a => `${a.icon} ${a.name}（${a.count}問）`).join("<br>")}
    </div>

    <div style="
      margin-top:8px;
      font-size:14px;
      color:#666;
    ">
      💡 次に勉強すると効果的！
    </div>

  </div>
  `;
}

document.getElementById("anatomy-box").innerHTML = `
🦴 解剖学：${anatomy}問<br><br>

🦴 骨：${bone}問<br>
💪 筋肉：${muscle}問<br>
🧠 神経：${nerve}問<br>
🫀 臓器：${organ}問<br>
🩸 血管：${vessel}問<br>
📍 断面・位置関係：${position}問

${weakMessage}
`;
const ctx = document.getElementById("radarChart");
new Chart(ctx, {
  type: "radar",
  data: {
    labels: [
      "骨",
      "筋肉",
      "神経",
      "臓器",
      "血管",
      "断面"
    ],
    datasets: [{
  label: "苦手問題数",
  data: [
    bone,
    muscle,
    nerve,
    organ,
    vessel,
    position
  ],
  borderColor: "#4A90E2",
  backgroundColor: "rgba(74,144,226,0.25)",
  pointBackgroundColor: "#4A90E2",
  pointBorderColor: "#4A90E2",
  borderWidth: 4
}]
  },
  options: {
    responsive: true,
    plugins: {
      legend: {
        display: false
      }
    },
    scales: {
      r: {
        beginAtZero: true,
        ticks: {
          stepSize: 1
        }
      }
    }
  }
});
</script>