<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div style="
  max-width: 700px;
  margin:5px auto 15px;
  text-align: center;
">

  <h1 style="
  font-size:24px;
  margin-top:0;
  margin-bottom:10px;
">
  🫀 生理学 苦手分析
</h1>

  <div id="physiology-box" style="
    background: white;
    padding: 10px 16px;
    border-radius: 18px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    font-size: 18px;
    font-weight: bold;
    line-height: 1.6;
  ">
  </div>

</div>

<div style="
  margin-top: 12px;
  background: white;
  padding: 16px;
  border-radius: 18px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
">

  <h2 style="
  font-size:18px;
  margin-bottom:10px;
">
  ⭐ 分野別 苦手度チャート
</h2>

  <div style="
    height:360px;
    display:flex;
    justify-content:center;
    align-items:center;
    color:#999;
    border-radius:12px;
  ">
    <canvas id="radarChart"></canvas>
  </div>
  <p style="
  text-align:right;
  font-size:11px;
  color:#888;
  margin-top:8px;
  margin-bottom:0;
  padding-right:8px;
">
  ※ レーダーチャートは5択・○×問題のみ集計しています
</p>

</div>

<script>
const wrong = JSON.parse(localStorage.getItem("wrong")) || []

let physiology = 0

let nervePhysiology = 0
let musclePhysiology = 0
let circulation = 0
let respiration = 0
let organ = 0
let hormone = 0
let digestion = 0
let homeostasis = 0

wrong.forEach(q => {

  if(q.category === "生理") physiology++

  if(q.subcategory === "神経生理") nervePhysiology++
  if(q.subcategory === "筋生理") musclePhysiology++
  if(q.subcategory === "循環") circulation++
  if(q.subcategory === "呼吸") respiration++
  if(q.subcategory === "内臓") organ++
  if(q.subcategory === "ホルモン") hormone++
  if(q.subcategory === "消化") digestion++
  if(q.subcategory === "体温・恒常性") homeostasis++

})

const weakAreas = [
  { name: "神経生理", icon: "🧠", count: nervePhysiology },
  { name: "筋生理", icon: "💪", count: musclePhysiology },
  { name: "循環", icon: "🫀", count: circulation },
  { name: "呼吸", icon: "🫁", count: respiration },
  { name: "内臓", icon: "🩺", count: organ },
  { name: "ホルモン", icon: "🧪", count: hormone },
  { name: "消化", icon: "🍚", count: digestion },
  { name: "体温・恒常性", icon: "🌡️", count: homeostasis }
];

const maxWeak = Math.max(...weakAreas.map(a => a.count));

let weakMessage = "";

if (maxWeak > 0) {
  const topWeak = weakAreas.filter(a => a.count === maxWeak);

  weakMessage = `
  <div style="
    margin-top:16px;
    padding:14px;
    background:#F8FBFF;
    border:1px solid #D6E8FF;
    border-radius:12px;
    text-align:center;
  ">

    <div style="
      font-size:18px;
      font-weight:bold;
    ">
      🥇 一番苦手：${topWeak.map(a => a.name).join("・")}
    </div>

    <div style="
      margin-top:8px;
      font-size:16px;
    ">
      ${topWeak.map(a => `${a.icon} ${a.name}（${a.count}問）`).join("<br>")}
    </div>

    <div style="
      margin-top:8px;
      font-size:14px;
      color:#666;
    ">
      💡 次に勉強すると効果的！
    </div>

  </div>
  `;
}

document.getElementById("physiology-box").innerHTML = `
🫀 生理学：${physiology}問<br><br>

🧠 神経生理：${nervePhysiology}問<br>
💪 筋生理：${musclePhysiology}問<br>
🫀 循環：${circulation}問<br>
🫁 呼吸：${respiration}問<br>
🩺 内臓：${organ}問<br>
🧪 ホルモン：${hormone}問<br>
🍚 消化：${digestion}問<br>
🌡️ 体温・恒常性：${homeostasis}問

${weakMessage}
`;
const ctx = document.getElementById("radarChart");

new Chart(ctx, {
  type: "radar",
  data: {
    labels: [
      "神経生理",
      "筋生理",
      "循環",
      "呼吸",
      "内臓",
      "ホルモン",
      "消化",
      "体温"
    ],
    datasets: [{
  label: "苦手問題数",
  data: [
    nervePhysiology,
    musclePhysiology,
    circulation,
    respiration,
    organ,
    hormone,
    digestion,
    homeostasis
  ],
  borderColor: "#4A90E2",
  backgroundColor: "rgba(74,144,226,0.25)",
  pointBackgroundColor: "#4A90E2",
  pointBorderColor: "#4A90E2",
  borderWidth: 4
    }]
  },
  options: {
    responsive: true,
    plugins: {
      legend: {
        display: false
      }
    },
    scales: {
      r: {
        beginAtZero: true,
        ticks: {
          stepSize: 1
        }
      }
    }
  }
});
</script>