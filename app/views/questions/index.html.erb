<script>
const score = Number(localStorage.getItem("score")) || 0;
const total = Number(localStorage.getItem("total")) || 0;

const rate = total > 0
  ? Math.round((score / total) * 100)
  : 0;

const degree = rate * 3.6;

const scoreRing = document.getElementById("score-ring");
const scorePercent = document.getElementById("score-percent");
const scoreCount = document.getElementById("score-count");
const scoreComment = document.getElementById("score-comment");

if (scoreRing) {
  scoreRing.style.background =
    `conic-gradient(
      #4da3ff 0deg,
      #4da3ff ${degree}deg,
      #e8edf3 ${degree}deg,
      #e8edf3 360deg
    )`;
}

if (scorePercent) {
  scorePercent.textContent = `${rate}%`;
}

if (scoreCount) {
  scoreCount.textContent = `${score} / ${total}問`;
}

if (scoreComment) {
  if (rate >= 80) {
    scoreComment.innerHTML =
      "🌟 すごい！しっかり身についてるね！<br>この調子で続けよう！";
  } else if (rate >= 60) {
    scoreComment.innerHTML =
      "✨ あと少し！いい調子！<br>復習したらもっと伸びるよ！";
  } else if (rate >= 40) {
    scoreComment.innerHTML =
      "⭐ 間違えた問題も、次の正解につながる大切なステップ！<br>一緒に頑張っていこう！";
  } else {
    scoreComment.innerHTML =
      "🌱 ここから伸びる！<br>もう一度挑戦してみよう！";
  }
}

const skeletonImage =
  rate >= 80
    ? "url('/images/top/happy_skeleton.png')"
    : "url('/images/top/sad_skeleton.png')";

document.body.style.setProperty("background-image", skeletonImage, "important");
document.body.style.setProperty("background-repeat", "no-repeat", "important");
document.body.style.setProperty("background-position", "center 75px", "important");
document.body.style.setProperty("background-size", "320px", "important");

// 正答率を見せてから、獲得したスタンプを表示
window.addEventListener("load", () => {
  const pendingStampJson = localStorage.getItem("pendingNewStamp");

  if (pendingStampJson) {
    try {
      const pendingStamp = JSON.parse(pendingStampJson);

      // 結果画面を約1.8秒見せてからご褒美演出
      setTimeout(() => {
        showStampModal(pendingStamp);
        localStorage.removeItem("pendingNewStamp");
      }, 1800);
    } catch (error) {
      console.error("pending stamp parse error:", error);
      localStorage.removeItem("pendingNewStamp");
    }
  }

  // 動作確認用：
  // 結果画面URLの末尾に &stamp_test=1 を付けた時だけ表示
  const params = new URLSearchParams(window.location.search);
  if (!pendingStampJson && params.get("stamp_test") === "1") {
    setTimeout(() => {
      showStampModal({
        image:"/images/stamps/normal/stamp_043.png",
        name:"通常スタンプ No.043"
      });
    }, 1800);
  }
});
</script>

<% end %>
