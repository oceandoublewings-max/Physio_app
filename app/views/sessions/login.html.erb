<!-- login.html.erb 完全版 -->
<style>
*{box-sizing:border-box}
body{
  margin:0;
  background:#eef3f9;
  font-family:sans-serif;
  color:#102847;
}
.login-page{
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:12px;
}
.login-card{
  width:100%;
  max-width:430px;
  background:#fff;
  border-radius:24px;
  overflow:hidden;
  box-shadow:0 12px 35px rgba(0,0,0,.12);
}
.hero{
  padding:22px 20px;
  text-align:center;
  color:#fff;
  background:linear-gradient(135deg,#041e42 0%,#0a4278 100%);
}
.hero h1{
  margin:0;
  font-size:30px;
  font-family:serif;
}
.hero p{
  margin:6px 0 0;
  color:#d8bd73;
  font-size:12px;
  letter-spacing:1px;
}
.content{
  padding:20px;
}
.skeleton{
  text-align:center;
  font-size:56px;
  margin-bottom:8px;
}
h2{
  margin:0;
  text-align:center;
  font-size:22px;
}
.description{
  margin:10px 0 20px;
  text-align:center;
  color:#666;
  line-height:1.6;
  font-size:17px;
}
.guest-btn{
  display:block;
  width:100%;
  padding:16px;
  border:none;
  border-radius:14px;
  background:linear-gradient(180deg,#3d86ea,#2d6fd3);
  color:#fff;
  font-size:19px;
  font-weight:bold;
  text-align:center;
  text-decoration:none;
}
.box{
  margin-top:18px;
  padding:16px;
  border-radius:14px;
  background:#f8fbff;
  border:1px solid #dfe6ef;
}
.box h3{
  margin:0 0 10px;
  text-align:center;
  font-size:24px;
}
.box ul{
  margin:0;
  padding-left:20px;
  line-height:2;
}
.soon{
  margin-top:20px;
  text-align:center;
  color:#666;
  line-height:1.8;
}
</style>

<div class="login-page">
  <div class="login-card">

    <div class="hero">
      <h1>⚕ PT国試対策</h1>
      <p>PHYSICAL THERAPIST NATIONAL EXAM PREP</p>
    </div>

    <div class="content">

      <div class="skeleton">💀</div>

      <h2>まずはゲストでお試し！</h2>

      <p class="description">
        登録不要ですぐ学習できます。<br>
        正式登録でデータを保存できます。
      </p>

      <%= button_to "👤 ゲストで始める",
          "/guest_login",
          method: :post,
          class: "guest-btn" %>

      <div class="box">
        <h3>ログインするとできること</h3>
        <ul>
          <li>📊 苦手分析</li>
          <li>🏅 スタンプ保存</li>
          <li>☁️ データ保存・引き継ぎ</li>
        </ul>
      </div>

      <div class="soon">
        <strong>正式版で追加予定</strong><br><br>
        🍎 Appleでログイン<br>
        🟢 Googleでログイン<br>
        ✉️ メールアドレスでログイン
      </div>

    </div>
  </div>
</div>
